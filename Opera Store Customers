<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بوابة العميل - OPERA STORE</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Cairo', sans-serif;
    background: #000000;
    color: #e8e8f0;
    min-height: 100vh;
    padding: 20px;
  }
  body[data-theme="light"] {
    background: #f0f0f8;
    color: #1a1a2e;
  }
  .container { max-width: 500px; margin: 0 auto; }
  
  /* Login Card */
  .login-card {
    background: #0d0d14;
    border: 1px solid rgba(130,120,210,0.12);
    border-radius: 28px;
    padding: 32px 24px;
    text-align: center;
    margin-top: 50px;
  }
  body[data-theme="light"] .login-card { background: #ffffff; }
  .login-card h2 {
    font-size: 1.8rem;
    font-weight: 900;
    background: linear-gradient(135deg, #fff, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .login-input { margin-bottom: 20px; text-align: right; }
  .login-input label { font-size: 0.75rem; font-weight: 600; margin-bottom: 6px; display: block; }
  .login-input input {
    width: 100%;
    padding: 14px;
    background: #13131e;
    border: 1px solid rgba(130,120,210,0.12);
    border-radius: 14px;
    color: #e8e8f0;
    font-family: 'Cairo', sans-serif;
    font-size: 1rem;
  }
  body[data-theme="light"] .login-input input { background: #f5f5fc; color: #1a1a2e; }
  .login-btn {
    background: #7c6bff;
    color: white;
    border: none;
    border-radius: 14px;
    padding: 14px;
    width: 100%;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    margin-top: 10px;
  }
  .error-msg { color: #f87171; font-size: 0.8rem; margin-top: 16px; }
  .theme-btn {
    position: fixed;
    top: 20px;
    left: 20px;
    background: #13131e;
    border: 1px solid rgba(130,120,210,0.12);
    border-radius: 30px;
    padding: 8px 16px;
    color: #a78bfa;
    cursor: pointer;
    font-size: 0.8rem;
  }
  
  /* Client Portal */
  .client-card {
    background: #0d0d14;
    border: 1px solid rgba(130,120,210,0.12);
    border-radius: 20px;
    padding: 20px;
    margin-bottom: 20px;
  }
  body[data-theme="light"] .client-card { background: #ffffff; }
  .client-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 20px;
  }
  .client-stat {
    background: #13131e;
    border-radius: 14px;
    padding: 16px 8px;
    text-align: center;
  }
  body[data-theme="light"] .client-stat { background: #f5f5fc; }
  .client-stat .lbl { font-size: 0.7rem; color: #6b6b8a; display: block; }
  .client-stat .val { font-size: 1.2rem; font-weight: 800; display: block; }
  .progress-bar-bg {
    height: 10px;
    background: #13131e;
    border-radius: 10px;
    overflow: hidden;
  }
  .progress-bar-fill { height: 100%; border-radius: 10px; transition: width 0.6s; }
  .payment-row {
    display: grid;
    grid-template-columns: 1fr 1.5fr 1fr;
    padding: 12px 0;
    border-bottom: 1px solid rgba(130,120,210,0.12);
    font-size: 0.85rem;
  }
  .logout-btn {
    background: transparent;
    border: 1px solid rgba(130,120,210,0.25);
    color: #6b6b8a;
    padding: 10px 16px;
    border-radius: 14px;
    cursor: pointer;
    margin-bottom: 20px;
  }
  .toast-container {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 999;
  }
  .toast {
    background: #1a1a28;
    padding: 10px 20px;
    border-radius: 30px;
    font-size: 0.8rem;
  }
</style>
</head>
<body>

<button class="theme-btn" onclick="toggleTheme()">🌙</button>

<div id="login-section" class="container">
  <div class="login-card">
    <h2>OPERA STORE</h2>
    <p>بوابة العملاء - استعلام عن عقدك</p>
    <div class="login-input">
      <label>رقم الهاتف</label>
      <input type="tel" id="client-phone" placeholder="01xxxxxxxxx">
    </div>
    <div class="login-input">
      <label>كلمة المرور</label>
      <input type="password" id="client-password" placeholder="كلمة المرور">
    </div>
    <button class="login-btn" onclick="clientLogin()">دخول</button>
    <div class="error-msg" id="login-error"></div>
  </div>
</div>

<div id="portal-section" class="container" style="display: none;">
  <button class="logout-btn" onclick="logout()"><i class="fa-solid fa-sign-out-alt"></i> خروج</button>
  
  <div class="client-card">
    <h3 id="client-name" style="font-size: 1.3rem; margin-bottom: 5px;">---</h3>
    <p id="client-prod" style="color: #a78bfa; font-size: 0.8rem;">---</p>
  </div>
  
  <div class="client-card">
    <div class="client-stats">
      <div class="client-stat"><span class="lbl">إجمالي العقد</span><span class="val" id="total-contract">0</span></div>
      <div class="client-stat"><span class="lbl">المدفوع</span><span class="val" id="total-paid" style="color: #34d399;">0</span></div>
      <div class="client-stat"><span class="lbl">المتبقي</span><span class="val" id="remaining" style="color: #fb923c;">0</span></div>
    </div>
    <div style="margin: 16px 0;">
      <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
        <span>تقدم السداد</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="progress-bar-bg"><div class="progress-bar-fill" id="progress-bar" style="width: 0%; background: #34d399;"></div></div>
    </div>
    <div style="display: flex; justify-content: space-between; padding-top: 12px; border-top: 1px solid rgba(130,120,210,0.12);">
      <div><span class="lbl" style="font-size: 0.7rem;">القسط الشهري</span><div id="monthly" style="font-size: 1.1rem; font-weight: 700;">0</div></div>
      <div><span class="lbl" style="font-size: 0.7rem;">أقساط متبقية</span><div id="months-left" style="font-size: 1.1rem; font-weight: 700;">0</div></div>
    </div>
  </div>
  
  <div class="client-card">
    <div style="display: flex; gap: 8px; margin-bottom: 16px;">
      <i class="fa-solid fa-clock-rotate-left"></i>
      <span style="font-weight: 700;">سجل الدفعات</span>
    </div>
    <div id="payments-list">
      <div class="payment-row" style="color: #6b6b8a; border-bottom: 2px solid rgba(130,120,210,0.25);">
        <span>المبلغ</span><span>التاريخ</span><span>ملاحظات</span>
      </div>
    </div>
  </div>
  
  <div class="client-card">
    <button class="login-btn" style="background: #25D366;" onclick="contactWhatsApp()">
      <i class="fa-brands fa-whatsapp"></i> التواصل عبر واتساب
    </button>
    <p style="font-size: 0.65rem; color: #6b6b8a; text-align: center; margin-top: 12px;">للتواصل: 01009144655</p>
  </div>
</div>

<div class="toast-container" id="toast-container"></div>

<script>
// Firebase Config
const firebaseConfig = {
  apiKey: "AIzaSyCUi3kogTKbON6HyKNXmIrgtyAVoI9h0t0",
  authDomain: "opera-store-7e04d.firebaseapp.com",
  projectId: "opera-store-7e04d",
  storageBucket: "opera-store-7e04d.firebasestorage.app"
};

// Import Firebase
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, doc, getDoc } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

let currentClient = null;
let allCustomers = [];

// تحميل البيانات من Firebase
async function loadData() {
  try {
    const snap = await getDoc(doc(db, "opera_store", "customers"));
    if(snap.exists()) {
      allCustomers = JSON.parse(snap.data().value);
    }
  } catch(e) {
    console.error("Firebase error:", e);
    showToast("خطأ في الاتصال", "error");
  }
}

function cleanPhone(phone) {
  return String(phone).replace(/\D/g, '');
}

function showToast(msg, type = 'success') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = 'toast';
  toast.innerHTML = msg;
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 2500);
}

function fmt(n) { return Number(n).toLocaleString('en-US'); }

function fmtDate(s) {
  if(!s) return "";
  const d = new Date(s);
  return `${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()}`;
}

window.clientLogin = async function() {
  await loadData();
  
  const phone = cleanPhone(document.getElementById('client-phone').value);
  const password = document.getElementById('client-password').value;
  const errorEl = document.getElementById('login-error');
  
  const client = allCustomers.find(c => {
    const cleanPhoneNum = cleanPhone(c.phone || '');
    return cleanPhoneNum === phone && c.clientPassword && c.clientPassword === password;
  });
  
  if(client) {
    currentClient = client;
    document.getElementById('login-section').style.display = 'none';
    document.getElementById('portal-section').style.display = 'block';
    renderClientPortal();
    showToast(`مرحباً ${client.name}`);
  } else {
    errorEl.textContent = '❌ رقم الهاتف أو كلمة المرور غير صحيحة';
  }
};

function renderClientPortal() {
  if(!currentClient) return;
  const c = currentClient;
  const paid = c.payments.reduce((s,p) => s + p.amount, 0);
  const ed = c.earlyDiscount || 0;
  const itc = c.total - c.down - ed;
  const rem = itc - paid;
  const pct = itc > 0 ? Math.min(100, Math.round((paid / itc) * 100)) : 0;
  const tm = c.monthly > 0 ? Math.ceil((c.total - c.down) / c.monthly) : 0;
  const paidMonths = c.monthly > 0 ? Math.floor((paid + ed) / c.monthly) : 0;
  const leftMonths = Math.max(0, tm - paidMonths);
  
  document.getElementById('client-name').textContent = c.name;
  document.getElementById('client-prod').textContent = `${c.prod || '---'} | التعاقد: ${fmtDate(c.receiveDate)} | يوم ${c.dueDay}`;
  document.getElementById('total-contract').textContent = fmt(itc);
  document.getElementById('total-paid').textContent = fmt(paid);
  document.getElementById('remaining').textContent = fmt(rem);
  document.getElementById('progress-pct').textContent = pct + '%';
  document.getElementById('progress-bar').style.width = pct + '%';
  document.getElementById('monthly').textContent = fmt(c.monthly);
  document.getElementById('months-left').textContent = leftMonths;
  
  const paymentsDiv = document.getElementById('payments-list');
  paymentsDiv.innerHTML = `<div class="payment-row" style="color: #6b6b8a; border-bottom: 2px solid rgba(130,120,210,0.25);"><span>المبلغ</span><span>التاريخ</span><span>ملاحظات</span></div>`;
  
  if(c.payments.length === 0) {
    paymentsDiv.innerHTML += '<div class="payment-row" style="justify-content: center;">لا توجد دفعات مسجلة</div>';
  } else {
    c.payments.slice().reverse().forEach(p => {
      const row = document.createElement('div');
      row.className = 'payment-row';
      row.innerHTML = `<span style="font-weight: 700; color: #34d399;">${fmt(p.amount)} ج.م</span><span style="color: #6b6b8a;">${p.date}</span><span style="color: #6b6b8a; font-size: 0.75rem;">${p.note || '---'}</span>`;
      paymentsDiv.appendChild(row);
    });
  }
}

window.contactWhatsApp = function() {
  if(!currentClient) return;
  const c = currentClient;
  const paid = c.payments.reduce((s,p) => s + p.amount, 0);
  const rem = (c.total - c.down - (c.earlyDiscount || 0)) - paid;
  const msg = `العميل: ${c.name}%0Aالهاتف: ${c.phone}%0Aالمنتج: ${c.prod}%0Aالمدفوع: ${fmt(paid)} ج.م%0Aالمتبقي: ${fmt(rem)} ج.م`;
  window.open(`https://wa.me/201009144655?text=${msg}`, '_blank');
};

window.logout = function() {
  currentClient = null;
  document.getElementById('login-section').style.display = 'block';
  document.getElementById('portal-section').style.display = 'none';
  document.getElementById('client-phone').value = '';
  document.getElementById('client-password').value = '';
};

window.toggleTheme = function() {
  const isLight = document.body.dataset.theme === 'light';
  if(isLight) {
    document.body.removeAttribute('data-theme');
    document.querySelector('.theme-btn').innerHTML = '🌙';
  } else {
    document.body.dataset.theme = 'light';
    document.querySelector('.theme-btn').innerHTML = '☀️';
  }
};

// Load data on start
loadData();
</script>
</body>
</html>
